# ── Anthropic (direct) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── TokenRouter — $200 free credit, 60+ models ────────────────────────────────
TOKENROUTER_API_KEY=tr_your_tokenrouter_api_key_here
TOKENROUTER_BASE_URL=https://api.tokenrouter.io/v1

# ── AgentHansa — returned by /api/agents/register (shown ONCE, save it) ──────
AGENT_KEY=tabb_your_agent_key_here
AGENTHANSA_BASE=https://www.agenthansa.com

# ── FluxA — returned by: npx @fluxa-pay/fluxa-wallet@latest init ──────────────
FLUXA_AGENT_ID=your_fluxa_agent_id_here

# ── BotLearn ──────────────────────────────────────────────────────────────────
BOTLEARN_API_KEY=your_botlearn_api_key_here
